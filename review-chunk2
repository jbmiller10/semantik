                )
                chunks = await fallback_chunker.chunk_text_async(text, doc_id, metadata)

                # Add fallback metadata
                for chunk in chunks:
                    if hasattr(chunk, "metadata"):
                        chunk.metadata["hybrid_chunker"] = True
                        chunk.metadata["selected_strategy"] = (
