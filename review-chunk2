import time
from typing import Any

import GPUtil
import psutil
from prometheus_client import CollectorRegistry, Counter, Gauge, Histogram, Info, start_http_server

logger = logging.getLogger(__name__)

# Re-export prometheus_client types for convenience
__all__ = [
