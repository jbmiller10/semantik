                    idx = text.find(content_stripped, start_idx)
                    if idx == -1:
                        break

                    # Check if this range overlaps with any used range
                    end_idx = idx + len(content_stripped)
                    overlaps = False

                    for used_start, used_end in used_ranges:
                        # Check for overlap
                        if not (end_idx <= used_start or idx >= used_end):
                            overlaps = True
                            break

